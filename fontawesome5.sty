%% fontawesome5.sty - uses system FontAwesome 6 Free
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{fontawesome5}[2024 FA6 Free using system font]

\RequirePackage{fontspec}
\RequirePackage{accsupp}

% Font paths for FontAwesome 6 Free (relative to project root)
\newfontfamily\FAFamilySolid{fonts/Font Awesome 6 Free-Solid-900}
\newfontfamily\FAFamilyBrands{fonts/Font Awesome 6 Brands-Regular-400}

% \faAlt{template}{icon}{text}
\def\faAlt#1#2#3{%
  \BeginAccSupp{ActualText={#1}}#2#3\EndAccSupp}

