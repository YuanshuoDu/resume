%% fontawesome5.sty - stub for pdflatex compatibility (text labels)
%% In XeLaTeX builds on CI/CD, the real fontawesome5 with glyphs is used.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{fontawesome5}[2024 stub for pdflatex]

% Provide \newfontfamily and \symbol as no-ops for pdflatex
\providecommand\newfontfamily[2][]{}
\providecommand\symbol[1]{\textbf{?}}

% Text-label icons (works with any engine)
\def\faGithub{{\sffamily GitHub}}
\def\faGithubAlt{{\sffamily GitHub}}
\def\faLinkedin{{\sffamily LinkedIn}}
\def\faLinkedinSquare{{\sffamily LinkedIn}}
\def\faTwitter{{\sffamily Twitter}}
\def\faTwitterSquare{{\sffamily Twitter}}
\def\faTwitterX{{\sffamily X}}
\def\faEnvelope{{\sffamily Email}}
\def\faPhone{{\sffamily Tel}}
\def\faMapMarker{{\sffamily Location}}
\def\faExternalLinkAlt{{\sffamily Link}}
\def\faGlobe{{\sffamily Globe}}
\def\faCheck{{\sffamily OK}}
\endinput
