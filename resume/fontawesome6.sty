%% fontawesome6.sty - uses system FontAwesome 4 font (system fonts-font-awesome package)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{fontawesome6}[2024 FA6 using system FontAwesome 4]

\RequirePackage{fontspec}
\RequirePackage{accsupp}

% Use system FontAwesome font - xelatex can find it via fc-list
\newfontfamily\FAFamily{Font Awesome 6 Free}
\newfontfamily\FAbrands{Font Awesome 6 Brands}

% \faAlt{template}{icon}{text} -> icon followed by text
\def\faAlt#1#2#3{%
  \BeginAccSupp{ActualText={#1}}#2#3\EndAccSupp}

