\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{simpleresume}[2024]

\LoadClass{article}
\RequirePackage[utf8]{inputenc}
\RequirePackage{geometry}
\RequirePackage{xcolor}
\RequirePackage{titlesec}

\geometry{a4paper,left=1.4cm,top=1.2cm,right=1.4cm,bottom=1.5cm}

\definecolor{skyblue}{RGB}{0,153,204}

\titleformat{\section}{\large\bfseries\color{skyblue}}{\thesection}{0.3em}{}
\titlespacing*{\section}{0pt}{0.5ex}{0.2ex}
