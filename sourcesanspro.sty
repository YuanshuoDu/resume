%% Custom sourcesanspro.sty - uses FreeSans as substitute
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{sourcesanspro}[2024 Custom sourcesanspro using FreeSans]

\RequirePackage{fontspec}

% Silently ignore all options
\DeclareOption*{}
\ProcessOptions\relax

% Define font family for FreeSans
\newfontfamily\SSPfamily{FreeSans}

% \sourcesanspro should just switch to sans-serif font family
% NOT \setmainfont which sets document main font (causes length issues)
\let\sourcesanspro\SSPfamily
\let\sourcesansprolight\SSPfamily  
\let\sourcesansprobold\SSPfamily
\let\sourcesansproit\SSPfamily
\let\sourcesansprobfit\SSPfamily
\let\sourcesanspromedium\SSPfamily

% Source Sans aliases
\let\SourceSansPro\SSPfamily
\let\SourceSansProLight\SSPfamily

\endinput
